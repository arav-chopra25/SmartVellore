# Environment
ENVIRONMENT=development

# Database
# Leave DATABASE_URL empty for local development; SQLite will be used automatically.
DATABASE_URL=
SQLITE_DATABASE_URL=sqlite:///./smartvellore.db

# Security
SECRET_KEY=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gemini AI (phased rollout)
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=20
GEMINI_PHASE=1
AI_TRIAGE_ON_CREATE=true

# SMTP Email Configuration (Optional - for sending confirmation emails)
# If these are not set, email notifications will be skipped gracefully

# Gmail Example:
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SENDER_EMAIL=noreply@smartvellore.com

# For Gmail: Generate an "App Password" at https://myaccount.google.com/apppasswords
# For other providers: Use your SMTP server details and credentials
